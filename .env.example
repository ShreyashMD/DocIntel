# ─── Required ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_generate_a_random_32_byte_key

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=docintel
POSTGRES_PASSWORD=docintel
POSTGRES_DB=docintel

# ─── Default LLM provider (companies can override in their org settings) ──────
DEFAULT_PROVIDER=gemini

# Fill in at least one of these — companies can add their own keys via /admin/settings
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=
