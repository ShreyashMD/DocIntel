FROM python:3.12-slim

WORKDIR /app

# System dependencies for OCR and PDF-to-image conversion
RUN apt-get update && apt-get install -y --no-install-recommends \
    tesseract-ocr \
    tesseract-ocr-eng \
    poppler-utils \
    libgl1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install uv

COPY pyproject.toml .
RUN uv pip install --system -e ".[server,postgres,graph,openai,office,ocr]"

COPY docintel/ ./docintel/

EXPOSE 8000
CMD ["python", "-m", "docintel.server"]
